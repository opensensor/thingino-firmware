-include $(M)/.config

ifeq ($(CONFIG_ATBM_APOLLO_WIFI6),)
CONFIG_ATBM_APOLLO_WIFI6 = m
endif

# Kernel 5.15: use the kernel's native cfg80211 instead of the bundled
# wireless/ backport, which only tracks older 5.x APIs.
#
# String values are read from .config with their double quotes intact. Strip
# them before using the values in Kbuild variables and quoted C definitions.
atbm_unq = $(strip $(subst ",,$(1)))

SDIO_BUS       ?= $(CONFIG_ATBM_SDIO_BUS_WIFI6)
USB_BUS        ?= $(CONFIG_ATBM_USB_BUS_WIFI6)
SPI_BUS        ?= $(CONFIG_ATBM_SPI_BUS_WIFI6)
MODULES_NAME   ?= $(call atbm_unq,$(CONFIG_ATBM_MODULE_NAME_WIFI6))
FW             ?= $(call atbm_unq,$(CONFIG_ATBM_FW_NAME_WIFI6))
IF1NAME        ?= $(call atbm_unq,$(CONFIG_ATBM_WIFIIF1_NAME_WIFI6))
IF2NAME        ?= $(call atbm_unq,$(CONFIG_ATBM_WIFIIF2_NAME_WIFI6))
USBVID         ?= $(CONFIG_ATBM_USB_VID_WIFI6)
USBPID         ?= $(CONFIG_ATBM_USB_PID_WIFI6)
SDIOVID        ?= $(CONFIG_ATBM_SDIO_VID_WIFI6)
SDIOPID        ?= $(CONFIG_ATBM_SDIO_PID_WIFI6)
MODDRVNAME     ?= $(call atbm_unq,$(CONFIG_ATBM_MODULE_DRIVER_NAME_WIFI6))
PLFDEVNAME     ?= $(call atbm_unq,$(CONFIG_ATBM_PLATFORM_DEVICE_NAME_WIFI6))
MODPMSTAYAWK   ?= $(call atbm_unq,$(CONFIG_ATBM_MODULE_PM_STAYAWK_WIFI6))
SAEAUTHEN      ?= $(CONFIG_ATBM_FUNC_SAE_AUTHEN_WIFI6)
LOAD_FW_H      ?= $(CONFIG_ATBM_USE_FIRMWARE_H_WIFI6)
BRIDGE         ?= $(CONFIG_ATBM_SUPPORT_BRIDGE_WIFI6)
MONITOR        ?= $(CONFIG_ATBM_FUNC_MONITOR_WIFI6)
NOTXCONFIRM    ?= $(CONFIG_ATBM_FUNC_NOTXCONFIRM_WIFI6)
MODULEFS       ?= $(CONFIG_ATBM_FUNC_MODULE_FS_WIFI6)
DEVCTRL        ?= $(CONFIG_ATBM_FUNC_DEV_CTRL_API_WIFI6)
PRI_IE         ?= $(CONFIG_ATBM_FUNC_PRIVE_IE_WIFI6)
BASETUP        ?= $(CONFIG_ATBM_FUNC_DRIVER_SETUP_AMPDU_WIFI6)
COUNTRY_CODE   ?= $(CONFIG_CPTCFG_CFG80211_COUNTRY_CODE_WIFI6)
COUNTRY_VAL    ?= $(call atbm_unq,$(CONFIG_ATBM_DEFAULT_COUNTRY_CODE_WIFI6))
CONFIG_CRONUS  ?= $(CONFIG_ATBM606x)
SDIO_HOST      ?= $(call atbm_unq,$(CONFIG_ATBM_SDIO_MMCx_WIFI6))
BLEPLATFORM    ?= $(CONFIG_ATBM_BLE_WIFI_PLATFORM_WIFI6)
BLECOEXIST     ?= $(CONFIG_ATBM_BLE_ADV_COEXIST_WIFI6)
BLUEDROID      ?= $(CONFIG_BLUEDROID_WIFI6)
BLE            ?= $(CONFIG_ATBM_BLE_WIFI6)
CUSTORMSPECIAL ?= y
SENDSPECIAL_MGMT ?= y
MULT_NAME      = y
ATBM_MAKEFILE_SUB = y

export CONFIG_ATBM_APOLLO_WIFI6
export SDIO_BUS USB_BUS SPI_BUS MODULES_NAME FW IF1NAME IF2NAME
export USBVID USBPID SDIOVID SDIOPID MODDRVNAME PLFDEVNAME MODPMSTAYAWK
export SAEAUTHEN LOAD_FW_H BRIDGE MONITOR NOTXCONFIRM MODULEFS DEVCTRL
export PRI_IE BASETUP COUNTRY_CODE COUNTRY_VAL CONFIG_CRONUS
ATBM_WIFI__EXT_CCFLAGS = -DATBM_WIFI_PLATFORM=PLATFORM_INGENICT41
export CUSTORMSPECIAL SENDSPECIAL_MGMT MULT_NAME ATBM_MAKEFILE_SUB SDIO_HOST
export BLEPLATFORM BLECOEXIST BLUEDROID BLE
export ATBM_WIFI__EXT_CCFLAGS
export CONFIG_ATBM_CONFIG_FILE CONFIG_ATBM_RATE_POWER_CONFIG_FILE
export CONFIG_ATBM_FW_NAME_WIFI6

obj-y += hal_apollo/
